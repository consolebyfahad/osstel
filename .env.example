# API (required) — include /api/v1 suffix
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:5001/api/v1
# EXPO_PUBLIC_API_BASE_URL=https://osstel-backend.vercel.app/api/v1

# Optional: LAN IP for physical device testing (when using local backend)
EXPO_PUBLIC_DEV_MACHINE_HOST=192.168.1.4
EXPO_PUBLIC_API_TIMEOUT=30000

# Google Sign-In (manager only; requires dev build, not Expo Go)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
