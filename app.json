{
  "expo": {
    "name": "OSSTEL",
    "slug": "osstel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/applogo.png",
    "scheme": "osstel",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.fa11ad.osstel",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.fa11ad.osstel",
      "icon": "./assets/images/applogo.png",
      "googleServicesFile": "./google-services.json",
      "permissions": ["POST_NOTIFICATIONS"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/applogo.png",
        "backgroundColor": "#69B4E8"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/applogo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "image": "./assets/images/osstellogo.png",
          "imageWidth": 220,
          "android": {
            "image": "./assets/images/osstellogo.png",
            "imageWidth": 220
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/applogo.png",
          "color": "#699274"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow OSSTEL to access your photos to update your profile picture."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
